rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Hymn audio — public, read-only. Uploads happen via the Firebase
    // console or admin SDK only; clients must never write here.
    match /hymns/{file} {
      allow read: if true;
      allow write: if false;
    }

    // TTS audio cache — written only by the ttsSpeak Cloud Function (admin
    // SDK, bypasses rules). Public read so cached clips are CDN-servable.
    match /tts/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-user uploads (future: profile photos, post images, attachments).
    // Owner-only writes, capped at 5 MB, images only.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else: denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
